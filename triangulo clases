class Triangulo
{
private:
    float base, altura;
public:
    float calculararea(float b, float h);
    Triangulo();
    ~Triangulo();
};
#include "Triangulo.h"
Triangulo::Triangulo() {
}
Triangulo::~Triangulo() {
}
float Triangulo::calculararea(float b, float h) {
	return(b * h) / 2;
}
#include <iostream>
#include "Triangulo.h"
using namespace std;
int main(){
	float base, altura;
	Triangulo triangulito;
	cout << "ingrese la base y altura" << endl;
	cin >> base >> altura;
	cout << "el area es " << triangulito.calculararea(base, altura);
	return 0;
}
